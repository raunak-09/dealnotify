{
  "manifest_version": 3,
  "name": "DealNotify - Price Drop & Restock Alerts",
  "version": "1.5.0",
  "description": "Get price drop & restock alerts. Compare prices at Walmart, Target, Best Buy, and Costco from Amazon product pages.",
  "content_security_policy": {
    "extension_pages": "script-src 'self' https://www.googletagmanager.com; object-src 'self'"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://www.dealnotify.co/*",
    "https://*.amazon.com/*",
    "https://*.walmart.com/*",
    "https://*.target.com/*",
    "https://*.bestbuy.com/*",
    "https://*.costco.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.amazon.co.uk/*",
        "*://*.amazon.ca/*",
        "*://*.walmart.com/*",
        "*://*.bestbuy.com/*",
        "*://*.target.com/*",
        "*://*.costco.com/*",
        "*://*.ebay.com/*"
      ],
      "js": ["comparison-panel.js", "content.js"],
      "css": ["comparison-panel.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
