FIRECRAWL_API_KEY=your_api_key_here

# Brevo — newsletter distribution
BREVO_API_KEY=your_brevo_api_key_here
BREVO_LIST_ID=                        # filled in automatically after first sync
BREVO_SENDER_EMAIL=hello@dealnotify.co
BREVO_SENDER_NAME=DealNotify

# ─── Crawl Strategy Phase 2 (added 2026-04-25) ───
# See docs/11 - Crawl Strategy.md. All optional; tiers no-op when keys absent.

# Tier-2 paid scraper (cheaper Firecrawl alternative).
# SCRAPER_PROVIDER options: firecrawl (default) | scraperapi | firecrawl-then-scraperapi
SCRAPER_PROVIDER=firecrawl
SCRAPER_API_KEY=                       # ScraperAPI key — sign up at https://www.scraperapi.com/

# Tier-1 retailer-native APIs (free, structured)
EBAY_APP_ID=                           # eBay App ID (OAuth Client ID) — https://developer.ebay.com/my/keys
EBAY_CERT_ID=                          # eBay Cert ID (OAuth Client Secret) — same page; used to mint 2h access tokens
BESTBUY_API_KEY=                       # Best Buy Open API — https://developer.bestbuy.com/
AMAZON_PA_ACCESS_KEY=                  # Amazon Product Advertising API 5.0 — Associates approval required
AMAZON_PA_SECRET_KEY=
AMAZON_PA_PARTNER_TAG=                 # Your Associates affiliate tag
